# ----------------------------------------------------------------------
# British Premier — Apache/LiteSpeed config (Hostinger)
# Lives in public/ so it is copied into dist/ on every build.
# Upload this file to the site root (public_html).
# ----------------------------------------------------------------------

# Use index.html as the directory default
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # If the site is served from a subfolder, set RewriteBase accordingly.
  RewriteBase /

  # --- Force HTTPS -----------------------------------------------------
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # --- Optional: force a single canonical host (uncomment ONE block) ---
  # Force non-www:
  # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  # RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
  #
  # Force www:
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # --- SPA / SSG fallback ---------------------------------------------
  # Real files and folders (the pre-rendered pages, assets, images,
  # sitemap.xml, robots.txt, the PDF, etc.) are served as-is.
  # Anything else falls back to the app shell so the React router can
  # handle the route — mirrors public/_redirects ( /* -> /index.html 200 ).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml application/rss+xml
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2 application/font-woff
</IfModule>

# ----------------------------------------------------------------------
# Caching
#   - Hashed build assets (/assets/*) are immutable -> cache 1 year.
#   - HTML must revalidate so deploys are picked up immediately.
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Images / fonts
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"

  # JS / CSS (filenames are content-hashed by Vite)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"

  # HTML — always revalidate
  ExpiresByType text/html                  "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Immutable for fingerprinted assets
  <FilesMatch "\.(?:css|js|woff2?|ttf|otf|eot|jpe?g|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Never cache the HTML shell / pre-rendered pages
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Basic security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------------
# Correct MIME types (in case the server is missing any)
# ----------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript          .js
  AddType text/css                        .css
  AddType image/svg+xml                   .svg
  AddType application/font-woff           .woff
  AddType font/woff2                      .woff2
  AddType application/pdf                 .pdf
</IfModule>
